# RAG Backend local development environment example.
# The sample password is only for local development. Do not use it in production.
# Copy to .env for local Docker Compose usage if needed; never commit real secrets.

SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080

POSTGRES_DB=rag_backend
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=rag_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

QDRANT_HOST=localhost
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

APP_CHUNK_SIZE=800
APP_CHUNK_OVERLAP=100

APP_EMBEDDING_PROVIDER=mock
APP_EMBEDDING_DIMENSION=384
